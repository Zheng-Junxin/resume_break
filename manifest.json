{
  "manifest_version": 3,
  "name": "Resume Break",
  "version": "0.4.0",
  "description": "Parse, edit, and tailor resumes against the current job description page.",
  "action": {
    "default_title": "Resume Break",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "optional_permissions": [
    "tabs"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
